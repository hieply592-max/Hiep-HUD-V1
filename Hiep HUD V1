local function ShowNotification(message, color)
    color = color or Color3.fromRGB(255, 60, 60)
    for _, child in pairs(NotifyContainer:GetChildren()) do
        if child:IsA("Frame") then
            TweenService:Create(child, TweenInfo.new(0.2), {Position = child.Position - UDim2.new(0, 0, 0, 45)}):Play()
        end
    end

    local NotifyFrame = Instance.new("Frame", NotifyContainer)
    NotifyFrame.Size = UDim2.new(1, 0, 0, 40)
    NotifyFrame.Position = UDim2.new(0, 350, 1, -45)
    NotifyFrame.BackgroundColor3 = Color3.fromRGB(15, 10, 10)
    Instance.new("UICorner", NotifyFrame).CornerRadius = UDim.new(0, 8)
    
    local Stroke = Instance.new("UIStroke", NotifyFrame)
    Stroke.Color = color
    Stroke.Thickness = 1.5

    local Text = Instance.new("TextLabel", NotifyFrame)
    Text.Size = UDim2.new(1, -15, 1, 0)
    Text.Position = UDim2.new(0, 12, 0, 0)
    Text.Text = "⚔️ " .. message
    Text.TextColor3 = Color3.fromRGB(255, 240, 240)
    Text.Font = Enum.Font.GothamBold
    Text.TextSize = 11
    Text.TextXAlignment = Enum.TextXAlignment.Left
    Text.BackgroundTransparency = 1

    NotifyFrame:TweenPosition(UDim2.new(0, 0, 1, -45), "Out", "Quad", 0.25, true)

    task.delay(4, function()
        TweenService:Create(NotifyFrame, TweenInfo.new(0.3), {BackgroundTransparency = 1}):Play()
        TweenService:Create(Text, TweenInfo.new(0.3), {TextTransparency = 1}):Play()
        TweenService:Create(Stroke, TweenInfo.new(0.3), {Transparency = 1}):Play()
        task.wait(0.3)
        NotifyFrame:Destroy()
    end)
end

