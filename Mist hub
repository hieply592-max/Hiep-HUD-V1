-- PHẦN 5: GENERATE KEY (CHẠY RIÊNG TRÊN MÁY TÍNH ĐỂ TẠO KEY)
-- Đây là script Python hoặc Lua riêng để tạo key phân phối
-- ============================================================

--[[
=== SCRIPT TẠO KEY (Python) ===
import random, string

TIEN_TO = "hipvn"
def tao_key(do_dai_khoi=4, so_khoi=3):
    bo_ky_tu = string.ascii_uppercase + string.digits
    khoi = [TIEN_TO]
    for _ in range(so_khoi):
        khoi.append(''.join(random.choice(bo_ky_tu) for _ in range(do_dai_khoi)))
    return '-'.join(khoi)

# Tạo 5 key
for i in range(5):
    print(tao_key())
--]]

