local SpatialCoreEngine = {}

function SpatialCoreEngine:VerifyInstanceIntegrity(modelInstance)
    if not modelInstance or not modelInstance:IsA("Model") or not modelInstance:FindFirstChild("Humanoid") then return false end
    if modelInstance.Humanoid.Health <= 0 then return false end
    return true
end

function SpatialCoreEngine:FetchValidTargetNape(searchLimit)
    local validatedTarget, minimumRegisteredDistance = nil, searchLimit or math.huge
    local characterInstance = LocalPlayer.Character
    if not characterInstance or not characterInstance:FindFirstChild("HumanoidRootPart") then return nil end
    local rootPartInstance = characterInstance.HumanoidRootPart
    
    local activeMapCollection = Workspace:FindFirstChild("Titans") or Workspace:FindFirstChild("Enemies") or Workspace
    for _, structuralModel in pairs(activeMapCollection:GetChildren()) do
        if self:VerifyInstanceIntegrity(structuralModel) then
            local structuralTargetPart = structuralModel:FindFirstChild("Nape") or structuralModel:FindFirstChild("Head")
            if structuralTargetPart then
                local computedDistance = (structuralTargetPart.Position - rootPartInstance.Position).Magnitude
                if computedDistance < minimumRegisteredDistance then
                    minimumRegisteredDistance, validatedTarget = computedDistance, structuralModel
                end
            end
        end
    end
    return validatedTarget
end

