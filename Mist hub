-- ============================================================
-- PHẦN 3: HÀM KIỂM TRA KEY VÀ THỰC THI SCRIPT
-- ============================================================

local function kiemTraVaChay(keyNhap)
    -- Chuẩn hóa key: bỏ khoảng trắng, viết hoa
    keyNhap = keyNhap:gsub("%s+", ""):upper()

    -- Kiểm tra tiền tố
    if not keyNhap:find("^" .. TIEN_TO_KEY:upper()) then
        return false, "Key phải bắt đầu bằng: " .. TIEN_TO_KEY
    end

    -- Kiểm tra độ dài tối thiểu (tránh key quá ngắn)
    if #keyNhap < #TIEN_TO_KEY + 8 then
        return false, "Key quá ngắn, không hợp lệ!"
    end

    -- Key hợp lệ
    return true, nil
end

local function thucThiScriptAOTR()
    -- Sử dụng loadstring để tải và chạy script từ URL
    local thanhCong, ketQua = pcall(function()
        local scriptTaiVe = game:HttpGet(SCRIPT_URL, true)
        local scriptChay = loadstring(scriptTaiVe)
        if scriptChay then
            scriptChay()
        else
            error("Không thể biên dịch script từ URL")
        end
    end)

    return thanhCong, ketQua
end

-- ============================================================
-- PHẦN 4: KHỞI TẠO GIAO DIỆN VÀ XỬ LÝ SỰ KIỆN
-- ============================================================

local gui, textBox, nutXacNhan, thongBao = taoGuiNhapKey()

nutXacNhan.MouseButton1Click:Connect(function()
    local keyNhap = textBox.Text

    if keyNhap == "" then
        thongBao.Text = "Vui lòng nhập key!"
        return
    end

    local hopLe, loi = kiemTraVaChay(keyNhap)

    if not hopLe then
        thongBao.Text = loi
        thongBao.TextColor3 = Color3.fromRGB(255, 100, 100)
        return
    end

    -- Key đúng -> ẩn GUI và chạy script
    thongBao.Text = "Key hợp lệ! Đang tải AOTR..."
    thongBao.TextColor3 = Color3.fromRGB(100, 255, 100)
    gui:Destroy() -- Xóa GUI key system

    -- Thực thi script AOTR
    local thanhCong, loiThucThi = thucThiScriptAOTR()

    if not thanhCong then
        -- Nếu lỗi, hiển thị thông báo trong console
        warn("[HIPVN] Lỗi khi chạy script AOTR: " .. tostring(loiThucThi))
    else
        print("[HIPVN] Script AOTR đã được tải và chạy thành công!")
    end
end)

-- Cho phép nhấn Enter để xác nhận
textBox.FocusLost:Connect(function(enterPressed)
    if enterPressed then
        nutXacNhan.MouseButton1Click:Fire()
    end
end)

