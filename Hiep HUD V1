-- [8. CORE LOGIC ENGINE XỬ LÝ GAMEPLAY AOTR]
task.spawn(function()
    while task.wait() do
        pcall(function()
            -- Đồng bộ hóa màn hình giảm lag
            RunService:Set3dRenderingEnabled(not _G.Settings.WhiteScreen)

            -- Xử lý Logic Vô hạn Ga và Lưỡi kiếm trong AOTR
            local Character = LocalPlayer.Character
            if Character then
                if _G.Settings.InfiniteGas and Character:FindFirstChild("GasTank") then
                    -- Thay đổi giá trị bình ga về mức tối đa liên tục
                    local Gas = Character.GasTank:FindFirstChild("Value") or Character.GasTank:FindFirstChild("Gas")
                    if Gas then Gas.Value = 100 end
                end
                
                if _G.Settings.InfiniteBlades and Character:FindFirstChild("Durability") then
                    -- Đóng băng độ bén của lưỡi kiếm không cho mòn
                    local Durability = Character.Durability:FindFirstChild("Value") or Character.Durability:FindFirstChild("Durability")
                    if Durability then Durability.Value = 100 end
                end
            end

            -- Thuật toán tìm kiếm và xử lý Titan (Targeting Nape - Chặt Gáy)
            if _G.Settings.AutoKillTitan and Character and Character:FindFirstChild("HumanoidRootPart") then
                local TargetTitan = nil
                -- Quét tìm mục tiêu trong thư mục Titans của không gian Workspace game AOTR
                local TitansFolder = workspace:FindFirstChild("Titans") or workspace:FindFirstChild("Enemies")
                if TitansFolder then
                    for _, titan in pairs(TitansFolder:GetChildren()) do
                        if titan:IsA("Model") and titan:FindFirstChild("Humanoid") and titan.Humanoid.Health > 0 then
                            -- Ưu tiên tìm bộ phận Nape (Gáy) của Titan để kết liễu nhanh
                            if titan:FindFirstChild("Nape") or titan:FindFirstChild("Head") then
                                TargetTitan = titan break
                            end
                        end
                    end
                end

                if TargetTitan then
                    local Hitbox = TargetTitan:FindFirstChild("Nape") or TargetTitan:FindFirstChild("Head")
                    if Hitbox then
                        -- Bay ra phía sau gáy của Titan 3 studs để thực hiện nhát chém chí mạng
                        Character.HumanoidRootPart.CFrame = Hitbox.CFrame * CFrame.new(0, 0, 3)
                        
                        -- Auto Fast Attack chém gáy liên tục
                        if _G.Settings.FastAttack then
                            local CombatRemote = ReplicatedStorage:FindFirstChild("Remotes") and ReplicatedStorage.Remotes:FindFirstChild("Attack")
                            if CombatRemote then
                                CombatRemote:FireServer("HitNape", TargetTitan.Name)
                            else
                                -- Giả lập click nếu không bắt được Remote của bản cập nhật mới
                                VirtualUser:CaptureController()
                                VirtualUser:ClickButton1(Vector2.new(850, 520))
                            end
                        end
                    end
                elseif _G.Settings.SafeMode then
                    -- Nếu hết sạch Titan trên bản đồ, đưa người chơi lên cao để né tránh tầm nhìn quái hồi sinh
                    Character.HumanoidRootPart.CFrame = CFrame.new(Character.HumanoidRootPart.Position.X, 1200, Character.HumanoidRootPart.Position.Z)
                end
            end

            -- Logic Auto Dodge (Tự động né đòn vả khi Titan giơ tay tấn công)
            if _G.Settings.AutoDodge and Character and Character:FindFirstChild("HumanoidRootPart") then
                local TitansFolder = workspace:FindFirstChild("Titans") or workspace:FindFirstChild("Enemies")
                if TitansFolder then
                    for _, titan in pairs(TitansFolder:GetChildren()) do
                        if titan:IsA("Model") and titan:FindFirstChild("HumanoidRootPart") then
                            local Distance = (titan.HumanoidRootPart.Position - Character.HumanoidRootPart.Position).Magnitude
                            -- Nếu Titan ở quá gần và đang kích hoạt trạng thái tấn công
                            if Distance < 25 and titan:GetAttribute("Attacking") == true then
                                -- Thực hiện lệnh né tránh bằng cách lướt lùi ra sau xa 40 studs lập tức
                                Character.HumanoidRootPart.CFrame = Character.HumanoidRootPart.CFrame * CFrame.new(0, 0, -40)
                                ShowNotification("Đã kích hoạt Auto Né Đòn thành công!", Color3.fromRGB(255, 150, 0))
                            end
                        end
                    end
                end
            end

            -- Tự động thu gom vật phẩm, vàng hoặc hộp tiếp tế sau trận đấu
            if _G.Settings.AutoCollectLoot then
                local Loots = workspace:FindFirstChild("Drops") or workspace:FindFirstChild("Loot")
                if Loots then
                    for _, item in pairs(Loots:GetChildren()) do
                        if item:IsA("Part") or item:IsA("MeshPart") then
                            Character.HumanoidRootPart.CFrame = item.CFrame
                            task.wait(0.05)
                        end
                    end
                end
            end
            
            -- Tự động thoát trận đấu khi phòng đã hoàn thành (Auto Leave Match)
            if _G.Settings.AutoLeaveMatch then
                local MatchState = ReplicatedStorage:FindFirstChild("MatchState")
                if MatchState and MatchState.Value == "Ended" then
                    ReplicatedStorage.Remotes.MenuRemote:FireServer("LeaveMatch")
                end
            end
        end)
    end
end)

