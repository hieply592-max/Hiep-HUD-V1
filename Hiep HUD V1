-- [5. ENGINE TẠO THÀNH PHẦN MENU ĐỘNG]
local Pages = {}
local CurrentPage = nil
local TabCount = 0

local function CreateTab(name)
    TabCount = TabCount + 1
    local TabBtn = Instance.new("TextButton", TabBar)
    TabBtn.Size = UDim2.new(1, -16, 0, 38)
    TabBtn.Position = UDim2.new(0, 8, 0, (TabCount-1)*44 + 8)
    TabBtn.Text = name
    TabBtn.TextColor3 = Color3.fromRGB(180, 150, 150)
    TabBtn.Font = Enum.Font.GothamSemibold
    TabBtn.TextSize = 12
    TabBtn.BackgroundColor3 = Color3.fromRGB(35, 20, 20)
    Instance.new("UICorner", TabBtn).CornerRadius = UDim.new(0, 6)

    local Page = Instance.new("ScrollingFrame", ContentArea)
    Page.Size = UDim2.new(1, 0, 1, 0)
    Page.BackgroundTransparency = 1
    Page.ScrollBarThickness = 3
    Page.ScrollBarImageColor3 = Color3.fromRGB(255, 60, 60)
    Page.CanvasSize = UDim2.new(0, 0, 0, 0)
    Page.Visible = false
    Page:SetAttribute("YOffset", 0)

    Pages[name] = {Btn = TabBtn, Page = Page}

    TabBtn.MouseButton1Click:Connect(function()
        if CurrentPage then
            CurrentPage.Btn.BackgroundColor3 = Color3.fromRGB(35, 20, 20)
            CurrentPage.Btn.TextColor3 = Color3.fromRGB(180, 150, 150)
            CurrentPage.Page.Visible = false
        end
        TabBtn.BackgroundColor3 = Color3.fromRGB(255, 60, 60)
        TabBtn.TextColor3 = Color3.fromRGB(15, 10, 10)
        Page.Visible = true
        CurrentPage = Pages[name]
    end)
    return Page
end

local function AddToggle(page, text, configKey)
    local yPos = page:GetAttribute("YOffset")
    local Frame = Instance.new("Frame", page)
    Frame.Size = UDim2.new(1, -8, 0, 40)
    Frame.Position = UDim2.new(0, 0, 0, yPos)
    Frame.BackgroundColor3 = Color3.fromRGB(32, 18, 18)
    Instance.new("UICorner", Frame).CornerRadius = UDim.new(0, 8)

    local Label = Instance.new("TextLabel", Frame)
    Label.Size = UDim2.new(0.7, 0, 1, 0)
    Label.Position = UDim2.new(0, 14, 0, 0)
    Label.Text = text
    Label.TextColor3 = Color3.fromRGB(245, 220, 220)
    Label.Font = Enum.Font.Gotham
    Label.TextSize = 12
    Label.TextXAlignment = Enum.TextXAlignment.Left
    Label.BackgroundTransparency = 1

    local Btn = Instance.new("TextButton", Frame)
    Btn.Size = UDim2.new(0, 36, 0, 18)
    Btn.Position = UDim2.new(1, -50, 0.5, -9)
    Btn.Text = ""
    Btn.BackgroundColor3 = Color3.fromRGB(70, 40, 40)
    Instance.new("UICorner", Btn).CornerRadius = UDim.new(1, 0)

    local Circle = Instance.new("Frame", Btn)
    Circle.Size = UDim2.new(0, 18, 0, 18)
    Circle.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
    Instance.new("UICorner", Circle).CornerRadius = UDim.new(1, 0)

    if _G.Settings[configKey] then
        Btn.BackgroundColor3 = Color3.fromRGB(255, 60, 60)
        Circle.Position = UDim2.new(1, -18, 0, 0)
    end

    Btn.MouseButton1Click:Connect(function()
        _G.Settings[configKey] = not _G.Settings[configKey]
        SaveSettings()
        if _G.Settings[configKey] then
            Btn.BackgroundColor3 = Color3.fromRGB(255, 60, 60)
            Circle:TweenPosition(UDim2.new(1, -18, 0, 0), "Out", "Quad", 0.12, true)
            ShowNotification("Đã kích hoạt: " .. text, Color3.fromRGB(255, 80, 80))
        else
            Btn.BackgroundColor3 = Color3.fromRGB(70, 40, 40)
            Circle:TweenPosition(UDim2.new(0, 0, 0, 0), "Out", "Quad", 0.12, true)
            ShowNotification("Đã hủy bỏ: " .. text, Color3.fromRGB(150, 100, 100))
        end
    end)

    page:SetAttribute("YOffset", yPos + 46)
    page.CanvasSize = UDim2.new(0, 0, 0, yPos + 50)
end

